NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Utilisés uniquement par scripts/send-weekly-email.ts (jamais côté client) :
# Supabase > Project Settings > API > service_role (secret, ne jamais préfixer NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Resend > API Keys
RESEND_API_KEY=your-resend-api-key
# Optionnel — adresse d'expédition (par défaut onboarding@resend.dev, sans domaine vérifié)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optionnel — pour inclure des liens cliquables vers les événements dans l'email
NEXT_PUBLIC_SITE_URL=http://localhost:3000
