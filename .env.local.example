NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Utilisés uniquement par scripts/send-weekly-email.ts et app/api/cron/weekly-email
# (jamais côté client) :
# Supabase > Project Settings > API > service_role (secret, ne jamais préfixer NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Resend > API Keys
RESEND_API_KEY=your-resend-api-key
# Optionnel — adresse d'expédition (par défaut onboarding@resend.dev, sans domaine vérifié —
# ne peut alors envoyer qu'à l'adresse du compte Resend lui-même, voir resend.com/domains)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optionnel — pour inclure des liens cliquables vers les événements dans l'email
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Protège /api/cron/weekly-email contre un appel externe non autorisé — même valeur
# ici et dans les variables d'environnement Vercel. Génère une valeur aléatoire, ex :
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-random-secret
